{
  "name": "imgtools",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run check:syntax && npm run check:types",
    "check:syntax": "node scripts/check-syntax.mjs",
    "check:types": "tsc -p tsconfig.json",
    "lint": "node scripts/lint.mjs",
    "serve:test": "node scripts/serve-static.mjs --port 4173",
    "test": "node --test",
    "test:ui": "playwright test",
    "test:ui:functional": "playwright test --grep-invert \"visual baseline\"",
    "test:visual": "playwright test tests/ui/visual.spec.js",
    "test:ui:update": "playwright test --update-snapshots",
    "test:perf": "playwright test -c playwright.perf.config.js",
    "test:all": "npm run check && npm run lint && npm test && npm run test:ui:functional && npm run test:perf"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "typescript": "^6.0.3"
  }
}
